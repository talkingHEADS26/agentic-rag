# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...          # Chat (gpt-4o) + Embeddings (text-embedding-3-small)

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...         # Service Role Key

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Google Calendar ───────────────────────────────────────────────────────────
# Setup: node googleAuth.js → führt OAuth Flow durch
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth2callback
GOOGLE_REFRESH_TOKEN=1//0...        # Von googleAuth.js generiert
GOOGLE_CALENDAR_ID=primary

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_TOKEN=EAAxxxxx
WHATSAPP_PHONE_ID=1234567890
WHATSAPP_VERIFY_TOKEN=dein-verify-secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
WIDGET_ORIGIN=https://talkingheads.business

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=dein-sicheres-passwort
