# ══════════════════════════════════════════════════════════════
# Agentic RAG Bot — Environment Variables
# Kopiere diese Datei zu .env und fülle alle Werte aus.
# ══════════════════════════════════════════════════════════════

# ── Branding ──────────────────────────────────────────────────
COMPANY_NAME=MeinUnternehmen
AGENT_NAME=MeinUnternehmen Assistent
COMPANY_TAGLINE=Digital Marketing         # Zeile unter dem Logo in der Bestätigungs-Mail
COMPANY_WEBSITE=https://meinunternehmen.de

# Widget-Farben (optional — Standard: blau/orange)
WIDGET_PRIMARY_COLOR=#0E51A0
WIDGET_ACCENT_COLOR=#EA9413

# Individuelle Begrüßungsnachricht (optional — leer lassen für Standard)
# WIDGET_WELCOME_MSG=Hallo! Wie kann ich dir helfen?

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...                # Chat (gpt-4o) + Embeddings (text-embedding-3-small)

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...              # Service Role Key (nicht der anon key!)

# ── Google Calendar ───────────────────────────────────────────
# Setup: node googleAuth.js → führt OAuth Flow durch → generiert REFRESH_TOKEN
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth2callback
GOOGLE_REFRESH_TOKEN=1//0...
GOOGLE_CALENDAR_ID=primary

# ── E-Mail (Terminbestätigung an Kunden) ──────────────────────
SMTP_HOST=smtp.meinprovider.de           # z.B. smtp.strato.de / smtp.gmail.com / smtp.ionos.de
SMTP_PORT=587                            # 587 = STARTTLS (empfohlen) | 465 = SSL
SMTP_USER=bot@meinunternehmen.de
SMTP_PASS=...

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────
WHATSAPP_TOKEN=EAAxxxxx
WHATSAPP_PHONE_ID=1234567890
WHATSAPP_VERIFY_TOKEN=dein-verify-secret # Frei wählbares Geheimwort für Webhook-Verifikation

# ── Admin-Interface ───────────────────────────────────────────
ADMIN_PASSWORD=dein-sicheres-passwort

# ── CORS (Widget-Embed auf externer Domain) ───────────────────
WIDGET_ORIGIN=https://meinunternehmen.de # Leer lassen = alle Domains erlaubt (*)

# ── Redis (automatisch via Docker Compose gesetzt) ────────────
REDIS_URL=redis://redis:6379

# ── Server ────────────────────────────────────────────────────
PORT=3000
